rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Customer service requests (created by customer, managed by staff/housekeeper in the app UI)
    match /ServiceRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.householderId == request.auth.uid;
      allow read: if signedIn()
        && (
          resource.data.householderId == request.auth.uid
          || resource.data.housekeeperId == request.auth.uid
        );

      // NOTE: This is intentionally permissive for the current prototype UI
      // (no custom claims are wired yet). Tighten this once staff roles are enforced
      // via custom claims / a Firestore-backed role model.
      allow update: if signedIn();
      allow delete: if false;
    }

    // In-app notifications written by staff actions and read by the customer.
    match /Notifications/{notificationId} {
      allow create: if signedIn();
      allow read: if signedIn() && resource.data.toUserId == request.auth.uid;
      allow update: if signedIn() && resource.data.toUserId == request.auth.uid;
      allow delete: if false;
    }

    // Default: deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
